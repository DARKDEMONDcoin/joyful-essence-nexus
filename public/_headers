/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(self), geolocation=(), payment=(self), usb=(), interest-cohort=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.lovable.app https://*.lovable.dev https://*.vercel-analytics.com https://*.vercel-insights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://*.ingest.de.sentry.io https://fonts.googleapis.com https://fonts.gstatic.com https://*.vercel-analytics.com https://*.vercel-insights.com https://ai.gateway.lovable.dev https://*.lovableproject.com https://*.lovable.app https://*.lovable.dev; worker-src 'self' blob:; child-src 'self' blob: https:; frame-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests



# HTML — stale-while-revalidate: يعرض النسخة المخزّنة فوراً (0ms) ويجدّدها في الخلفية.
# التحديثات توصل بعد أول زيارة ثانية بدون فرض round-trip يحجب الرسم.
/
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/index.html
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

# ملفات Vite الناتجة (فيها hash في الاسم) — آمنة للتخزين سنة كاملة
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# الصور والـ favicons — كاش يوم واحد + revalidate
/*.png
  Cache-Control: public, max-age=86400, must-revalidate
/*.jpg
  Cache-Control: public, max-age=86400, must-revalidate
/*.webp
  Cache-Control: public, max-age=86400, must-revalidate
/*.avif
  Cache-Control: public, max-age=86400, must-revalidate
/*.svg
  Cache-Control: public, max-age=86400, must-revalidate

# OG/Twitter image — قصير علشان السوشيال يلتقط التحديث
/og-megsy.jpg
  Cache-Control: public, max-age=3600, must-revalidate

# Sitemap & robots — لا كاش
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
/sitemap-index.xml
  Cache-Control: public, max-age=0, must-revalidate
/sitemap-media.xml
  Cache-Control: public, max-age=0, must-revalidate
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
